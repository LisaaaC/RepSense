# ─────────────────────────────────────────────────────────
# RepSense AI — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the Claude model used
# claude-haiku-4-5-20251001 (fast, cheap) | claude-sonnet-4-6 (smarter, pricier)
CLAUDE_MODEL=claude-haiku-4-5-20251001


# ── WhatsApp Business Cloud API ───────────────────────────
# Get from: Meta Developer Dashboard → Your App → WhatsApp → API Setup

# The numeric ID of your WhatsApp phone number
WHATSAPP_PHONE_NUMBER_ID=1234567890

# Temporary access token (24h) or permanent System User token
WHATSAPP_ACCESS_TOKEN=EAAxxxxx...

# A secret string YOU invent — paste the same one into Meta Dashboard → Webhook
WHATSAPP_VERIFY_TOKEN=repsense_verify_token


# ── Server ────────────────────────────────────────────────
PORT=8000
